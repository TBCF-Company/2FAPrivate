{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=privacyidea;Username=privacyidea;Password=your_secure_password",
    "PostgreSQL": "Host=localhost;Port=5432;Database=privacyidea;Username=privacyidea;Password=your_secure_password",
    "MySQL": "Server=localhost;Port=3306;Database=privacyidea;User=privacyidea;Password=your_secure_password",
    "SQLite": "Data Source=privacyidea.db"
  },
  
  "Database": {
    "Provider": "PostgreSQL"
  },
  
  "Jwt": {
    "Secret": "your-super-secret-jwt-key-min-32-characters-long",
    "Issuer": "PrivacyIDEA",
    "Audience": "PrivacyIDEA-API",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },

  "PrivacyIDEA": {
    "EncryptionKeyFile": "enckey",
    "AuditKeyFile": "audit.key",
    "DefaultRealm": "default",
    "PrependPin": true,
    "FailCounterIncOnFalsePin": true,
    "AutoResync": false,
    "DefaultResetFailCount": true
  },

  "Redis": {
    "Enabled": false,
    "ConnectionString": "localhost:6379"
  }
}
